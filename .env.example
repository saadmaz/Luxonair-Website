# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
# Add these same values in Hostinger hPanel -> Node.js -> Environment Variables.

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Database 
DATABASE_URL=mysql://username:password@127.0.0.1:3306/dbname

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate a secure random secret (e.g. openssl rand -hex 32)
JWT_SECRET=replace-with-a-long-random-string

# Admin login credentials
ADMIN_EMAIL=admin@luxeonair.co.uk

# Generate the bcrypt hash of your password and paste it here:
#   node -e "const b=require('bcryptjs'); console.log(b.hashSync('yourpassword', 12))"

