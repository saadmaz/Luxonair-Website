# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
# Add these same keys in Hostinger hPanel → Node.js → Environment Variables.

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Database ─────────────────────────────────────────────────────────────────
# Full MySQL connection URL. Format:
#   mysql://USERNAME:PASSWORD@HOST:PORT/DATABASE
# On Hostinger the host is usually 127.0.0.1 (the app and DB share the same server).
DATABASE_URL=mysql://username:password@127.0.0.1:3306/dbname

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate a secure random secret (minimum 32 bytes of hex):
#   openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars

# ─── Admin credentials ────────────────────────────────────────────────────────
# The email address used to log in to the admin dashboard.
ADMIN_EMAIL=admin@luxeonair.co.uk

# bcrypt hash of the admin password. Generate with:
#   node -e "require('bcryptjs').hash('yourpassword', 12).then(console.log)"
# Then paste the full $2b$... string here.
ADMIN_PASSWORD_HASH=$2b$12$replacethiswitharealbcrypthashofyourpassword
