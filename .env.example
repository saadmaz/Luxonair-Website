# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
# Add these same values in Hostinger hPanel -> Node.js -> Environment Variables.

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Database (Neon serverless Postgres) ──────────────────────────────────────
# Create a free DB at https://neon.tech → Project Settings → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate a secure random secret (e.g. openssl rand -hex 32)
JWT_SECRET=replace-with-a-long-random-string

# Admin login credentials
ADMIN_EMAIL=admin@luxeonair.co.uk

# Generate the bcrypt hash of your password and paste it here:
#   node -e "const b=require('bcryptjs'); console.log(b.hashSync('yourpassword', 12))"
ADMIN_PASSWORD_HASH=$2b$12$replacethiswithyourrealbcrypthash
